{
  "name": "glab-axi",
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.1",
  "description": "AXI-compliant glab CLI wrapper - token-efficient TOON output, contextual suggestions, idempotent mutations",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:fahmiauliarahman/glab-axi.git"
  },
  "keywords": [
    "gitlab",
    "cli",
    "agent",
    "axi",
    "toon",
    "glab"
  ],
  "bin": {
    "glab-axi": "./dist/bin/glab-axi.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx bin/glab-axi.ts",
    "lint": "eslint src test bin eslint.config.mjs",
    "format": "prettier --write \"src/**/*.{ts,js,mjs,cjs,json,md}\" \"test/**/*.ts\" \"bin/**/*.ts\" \"README.md\" \"package.json\" \"eslint.config.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,mjs,cjs,json,md}\" \"test/**/*.ts\" \"bin/**/*.ts\" \"README.md\" \"package.json\" \"eslint.config.mjs\"",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "axi-sdk-js": "^0.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.0.0"
  }
}
